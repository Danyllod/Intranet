# Configuração de Variáveis de Ambiente
# Copie este arquivo para .env e configure com seus valores

# Configuração da aplicação: development, production, testing
# ℹ️  FLASK_CONFIG define qual classe de configuração usar (não FLASK_ENV)
FLASK_CONFIG=development

# Chave secreta para assinar sessões e tokens
# ⚠️  IMPORTANTE: Em produção, define uma chave forte e aleatória!
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-this-in-production

# Configuração de Debug (não use True em produção!)
FLASK_DEBUG=True

# Porta do servidor (padrão: 5000)
FLASK_PORT=5000

# Host do servidor (padrão: 127.0.0.1, use 0.0.0.0 para acessar de outras máquinas)
FLASK_HOST=127.0.0.1
